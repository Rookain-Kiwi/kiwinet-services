# ─────────────────────────────────────────────────────────────────────────────
# kiwinet-infra/.gitignore
# ─────────────────────────────────────────────────────────────────────────────

# Variables d'environnement — ne jamais versionner
.env

# Les credentials de Komga contenus dans le yaml — ne jamais versionner
komf/config/application.yml

# Certificats Let's Encrypt — régénérés automatiquement par Traefik
traefik/acme.json
traefik/acme.vps.json

# Identifiants basic auth — générer avec : htpasswd -nB <utilisateur> >> traefik/.htpasswd
traefik/.htpasswd

# ── Home Assistant ────────────────────────────────────────────────────────────
# Données HA persistantes — volumineuses et contiennent des secrets
ha/config/

# Données et logs Mosquitto
ha/mosquitto/data/
ha/mosquitto/log/

# ── Système ───────────────────────────────────────────────────────────────────
.DS_Store
*.swp
*.swo
# ─────────────────────────────────────────────────────────────────────────────
# kiwinet-services/.gitignore
# ─────────────────────────────────────────────────────────────────────────────

# Variables d'environnement — ne jamais versionner
.env
*.env

# Certificats Let's Encrypt — régénérés automatiquement par Traefik
traefik/acme.json
traefik/acme.vps.json

# Identifiants basic auth — générer avec : htpasswd -nB <utilisateur> >> traefik/.htpasswd
traefik/.htpasswd

# Credentials Komga contenus dans yaml — ne jamais versionner
komf/config/application.yml

# ── Home Assistant ────────────────────────────────────────────────────────────
# Données HA persistantes — volumineuses et contiennent des secrets
ha/config/
# Données et logs Mosquitto
ha/mosquitto/data/
ha/mosquitto/log/

# ── PostgreSQL ────────────────────────────────────────────────────────────────
postgres/.env
pgadmin/.env
searxng/.env

# ── Synapse (Matrix) ──────────────────────────────────────────────────────────
# Données Synapse persistantes — volumineuses et contiennent des secrets
synapse/data/
# Logs Synapse
synapse/logs/

# ── Système ───────────────────────────────────────────────────────────────────
.DS_Store
*.swp
*.swo

# ── SeedBox ───────────────────────────────────────────────────────────────────
traefik/dynamic/dynamic.seedbox.yml
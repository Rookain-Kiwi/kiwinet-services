# ============================================================================
# Synapse — Secrets et Credentials
# ============================================================================
# À remplir avec les vraies valeurs sur le VPS
# Générer avec: openssl rand -base64 32 ou openssl rand -hex 32
# ============================================================================

# PostgreSQL credentials
# Générer avec: openssl rand -base64 32
SYNAPSE_DB_PASSWORD=

# Synapse macaroon secret (clé de signature des tokens)
# Générer avec: openssl rand -hex 32
SYNAPSE_MACAROON_SECRET=

# Synapse registration secret (token pour synapse_register_new_matrix_user)
# Générer avec: openssl rand -base64 32
SYNAPSE_REGISTRATION_SECRET=
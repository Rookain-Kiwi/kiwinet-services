# ============================================================================
# Synapse Secrets Configuration (.env)
# ============================================================================
# IMPORTANT: Copie ce fichier en .env et complète les valeurs
# DO NOT COMMIT .env au git — reste en .gitignore
# ============================================================================

# [PostgreSQL] Root password (du déploiement ÉTAPES 1-2)
POSTGRES_ROOT_PASSWORD=<ROOT_PASSWORD_POSTGRESQL>

# [Synapse] Database connection password
# À utiliser tel quel du déploiement ÉTAPES 1-2
SYNAPSE_DB_PASSWORD=_fj_GWsvSBwv6rhZD-5450gvg7SmuchWBaqaY_rDjcKyqeFaUBfXjIYkoJJm8j1f

# [Synapse] Macaroon secret key
# Génération: python3 -c "import secrets; print(secrets.token_hex(32))"
# Fonction: Signature des tokens d'authentification
# Longueur: 64 caractères hexadécimaux
SYNAPSE_MACAROON_SECRET=<MACAROON_SECRET_HEX_32>

# [Synapse] Registration shared secret
# Génération: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Fonction: Authentification pour synapse_register_new_matrix_user
# Longueur: 32+ caractères URL-safe
SYNAPSE_REGISTRATION_SECRET=<REGISTRATION_SECRET_URLSAFE_32>

# ============================================================================
# Instructions de génération
# ============================================================================
# 
# MACAROON_SECRET:
#   $ python3 -c "import secrets; print(secrets.token_hex(32))"
#   Exemple: a1b2c3d4e5f6... (64 caractères)
#
# REGISTRATION_SECRET:
#   $ python3 -c "import secrets; print(secrets.token_urlsafe(32))"
#   Exemple: a1b2c3d4-e5f6_g7h8... (URL-safe)
#
# ============================================================================
# Sécurité
# ============================================================================
#
# ✅ DO:
#   - Générer des secrets aléatoires cryptographiquement forts
#   - Stocker .env en local sécurisé
#   - Charger depuis un gestionnaire de secrets en prod
#   - Jamais commit .env au git
#
# ❌ DON'T:
#   - Réutiliser les mêmes secrets entre services
#   - Versionner .env dans git
#   - Partager les secrets par email
#   - Utiliser des mots de passe faibles
#
# ============================================================================
